# ---------------------------------------------------------------------------
# MeetingMind AI — Backend environment configuration
# Copy this file to `.env` and adjust for your local machine.
# ---------------------------------------------------------------------------

# Core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=meetingmind
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# CORS / CSRF (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT lifetimes (minutes / days)
JWT_ACCESS_TOKEN_LIFETIME_MIN=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# Run tasks synchronously in-process (True for local dev without Redis/Celery)
CELERY_TASK_ALWAYS_EAGER=True

# Email (console backend prints emails to the terminal in local dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=MeetingMind AI <no-reply@meetingmind.local>
FRONTEND_BASE_URL=http://localhost:3000

# AI provider: anthropic | openai | mock
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Speech-to-text: faster-whisper | mock
STT_PROVIDER=mock
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Uploads
MAX_UPLOAD_SIZE_MB=500
